{
  "name": "rentledger",
  "version": "0.1.0",
  "private": true,
  "description": "RentLedger — rental-management SaaS backend (India-first, multi-jurisdiction-ready).",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @rentledger/api start:dev",
    "build": "pnpm --filter @rentledger/api build",
    "start": "pnpm --filter @rentledger/api start:prod",
    "test": "pnpm --filter @rentledger/api test",
    "test:watch": "pnpm --filter @rentledger/api test:watch",
    "typecheck": "pnpm --filter @rentledger/api typecheck",
    "db:migrate": "pnpm --filter @rentledger/api db:migrate",
    "db:seed": "pnpm --filter @rentledger/api db:seed",
    "db:reset": "pnpm --filter @rentledger/api db:reset"
  }
}
