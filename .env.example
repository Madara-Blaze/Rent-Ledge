# --- Runtime ---
NODE_ENV=development
PORT=3000
# Comma-separated CORS origins for the future web client
CORS_ORIGINS=http://localhost:5173

# --- Database (Postgres) ---
# matches docker-compose.yml
DATABASE_URL=postgresql://rentledger:rentledger@localhost:5432/rentledger

# --- Redis (queues / cache / idempotency) ---
REDIS_URL=redis://localhost:6379

# --- Auth (placeholder for Phase 1 — not yet wired in the financial-core slice) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Encryption (PAN / Aadhaar / bank details at rest) ---
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=Y2hhbmdlLW1lLXRoaXMtaXMtbm90LWEtcmVhbC1rZXkhIQ==

# --- Default jurisdiction / locale ---
DEFAULT_JURISDICTION=IN
DEFAULT_CURRENCY=INR
DEFAULT_LOCALE=en-IN
DEFAULT_TIMEZONE=Asia/Kolkata
