# esbuild's binary ships via its platform package, so its skipped postinstall is
# harmless — but pnpm 11 treats skipped builds as fatal on install, and the
# verify-deps pre-check runs install before every script. Disable that pre-check
# so `pnpm test` / `pnpm typecheck` run without re-triggering install.
verify-deps-before-run=false
